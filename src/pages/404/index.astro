---
import { getLangFromUrl } from "../../i18n/utils";
import Layout from "../../layouts/Layout.astro";

const lang = getLangFromUrl(Astro.url);
---

<Layout title="Página no encontrada - La Despensa de Claudio">
    <main class="w-full min-h-[80vh] flex items-center justify-center bg-stone-50 px-4">
        <div class="max-w-2xl w-full text-center">
            <div class="mb-8 flex justify-center">
                <div class="relative">
                    <span class="text-[12rem] font-serif text-stone-200 leading-none select-none">404</span>
                    <div class="absolute inset-0 flex items-center justify-center">
                        <span class="text-3xl md:text-4xl font-serif text-green-900 mt-8">Bocado no encontrado</span>
                    </div>
                </div>
            </div>

            <h1 class="text-2xl md:text-3xl font-serif text-stone-800 mb-4">
                Parece que esta pieza no está en nuestra bodega
            </h1>
            
            <p class="text-stone-600 font-light leading-relaxed mb-10 max-w-md mx-auto">
                Lo sentimos, la página que buscas no existe o ha sido movida. 
                Te invitamos a volver a nuestra selección exclusiva para seguir disfrutando de lo mejor de nuestra tierra.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a 
                    href="/" 
                    class="bg-green-900 hover:bg-green-800 text-white font-bold py-4 px-8 rounded-sm shadow-md transition-all duration-300 uppercase text-xs tracking-[0.2em]"
                >
                    Volver al Inicio
                </a>
                <a 
                    href={`${lang}/products`} 
                    class="border border-stone-300 hover:border-green-900 text-stone-600 hover:text-green-900 font-bold py-4 px-8 rounded-sm transition-all duration-300 uppercase text-xs tracking-[0.2em]"
                >
                    Ver Catálogo
                </a>
            </div>
        </div>
    </main>
</Layout>

<style>
    /* Animación suave para el número de fondo */
    h1, p, a {
        animation: fadeIn 0.8s ease-out forwards;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>