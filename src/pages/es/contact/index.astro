---
import { Image } from "astro:assets";
import Layout from "../../../layouts/Layout.astro";
import BUS_DATA from "../../../docs/bussiness-data.json";

import instagramLogo from "../../../assets/images/instagram-logo.webp";
import facebookLogo from "../../../assets/images/facebook-logo.png";

// SVG
import PhoneSVG from "../../../assets/svg/phone.svg";
import MailSVG from "../../../assets/svg/mail.svg";
import AnalogClockSVG from "../../../assets/svg/analog-clock.svg";
import LocationSVG from "../../../assets/svg/location.svg"


const tabName = "Contacto";
---

<Layout title={`${tabName} - La Despensa de Claudio`}>
    <main class="w-full min-h-screen bg-stone-50 font-sans text-stone-800">
        
        <section class="bg-green-900 py-10 px-4 text-center">
            <h1 class="text-4xl md:text-6xl font-serif text-white mb-4">Contacto</h1>
            <p class="text-green-50 font-light max-w-2xl mx-auto text-lg">
                ¿Tienes alguna duda sobre nuestros productos? 
                Te asesoramos de forma personalizada.
            </p>
        </section>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
                
                <div class="flex flex-col gap-10">
                    <div>
                        <h2 class="text-2xl font-serif text-green-900 mb-6 underline decoration-stone-300 underline-offset-8">
                            Atención al Cliente
                        </h2>
                        
                        <div class="space-y-6">
                            <div class="flex items-start gap-4">
                                <div class="bg-white p-3 shadow-sm rounded-sm text-green-800">
                                    <PhoneSVG />
                                </div>
                                <div>
                                    <h4 class="font-bold text-stone-900">Teléfono</h4>
                                    <p class="text-stone-600 font-light">{BUS_DATA.phone_number}</p>
                                </div>
                            </div>

                            <div class="flex items-start gap-4">
                                <div class="bg-white p-3 shadow-sm rounded-sm text-green-800">
                                    <MailSVG />
                                </div>
                                <div>
                                    <h4 class="font-bold text-stone-900">Email</h4>
                                    <p class="text-stone-600 font-light">{BUS_DATA.email}</p>
                                </div>
                            </div>

                            <div class="flex items-start gap-4">
                                <div class="bg-white p-3 shadow-sm rounded-sm text-green-800">
                                    <LocationSVG />
                                </div>
                                <div>
                                    <h4 class="font-bold text-stone-900">Dirección</h4>
                                    <p class="text-stone-600 font-light">{BUS_DATA.address}</p>
                                </div>
                            </div>

                            <div class="flex items-start gap-4">
                                <div class="bg-white p-3 shadow-sm rounded-sm text-green-800">
                                    <AnalogClockSVG />
                                </div>
                                <div>
                                    <h4 class="font-bold text-stone-900">Horario</h4>
                                    <p class="text-stone-600 font-light">Lunes a Viernes:</p>
                                    <p class="text-stone-600 font-light">- Mañana: 08:30 - 14:30</p>
                                    <p class="text-stone-600 font-light">- Tarde: 17:30 - 21:00</p>
                                    <p class="text-stone-600 font-light">Sábados: 9:00 - 14:30</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="pt-8 border-t border-stone-200">
                        <h4 class="text-xs font-bold uppercase tracking-widest text-stone-400 mb-4">Síguenos</h4>
                        <div class="flex gap-4">
                            <a href="https://www.instagram.com/ladespensadeclaudio/" class="flex justify-center items-center">
                                <Image src={instagramLogo} alt={'Logo Instagram'} class="size-20"/>
                            </a>
                            <a href="https://www.facebook.com/ladespensa.declaudio/" class="flex justify-center items-center">
                                <Image src={facebookLogo} alt={'Facebook Logo'} class="size-10"/>
                            </a>
                        </div>
                    </div>
                </div>

                <div class="bg-white p-8 md:p-12 shadow-xl shadow-stone-200/50 rounded-sm border border-stone-100">
                    <form id="contact-form" action="#" class="flex flex-col gap-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="flex flex-col gap-2">
                                <label for="name" class="text-xs font-bold uppercase tracking-wider text-stone-500">Nombre completo</label>
                                <input 
                                    type="text" 
                                    id="name" 
                                    name="name"
                                    required
                                    placeholder="Ej. Claudio González"
                                    class="bg-stone-50 border border-stone-200 rounded-sm py-3 px-4 focus:outline-none focus:border-green-800 transition-colors"
                                />
                            </div>
                            <div class="flex flex-col gap-2">
                                <label for="email" class="text-xs font-bold uppercase tracking-wider text-stone-500">Correo electrónico</label>
                                <input 
                                    type="email" 
                                    id="email" 
                                    name="email"
                                    required
                                    placeholder="claudio@ejemplo.com"
                                    class="bg-stone-50 border border-stone-200 rounded-sm py-3 px-4 focus:outline-none focus:border-green-800 transition-colors"
                                />
                            </div>
                        </div>

                        <div class="flex flex-col gap-2">
                            <label for="subject" class="text-xs font-bold uppercase tracking-wider text-stone-500">Asunto</label>
                            <select id="subject" name="subject" required class="bg-stone-50 border border-stone-200 rounded-sm py-3 px-4 focus:outline-none focus:border-green-800 transition-colors">
                                <option value="Consulta sobre productos">Consulta sobre productos</option>
                                <option value="Pedido / Reserva">Pedido / Reserva</option>
                                <option value="Otro motivo">Otro motivo</option>
                            </select>
                        </div>

                        <div class="flex flex-col gap-2">
                            <label for="message" class="text-xs font-bold uppercase tracking-wider text-stone-500">Mensaje</label>
                            <textarea 
                                id="message" 
                                name="message"
                                required
                                rows="5" 
                                placeholder="Escribe aquí tu consulta..."
                                class="bg-stone-50 border border-stone-200 rounded-sm py-3 px-4 focus:outline-none focus:border-green-800 transition-colors resize-none"
                            ></textarea>
                        </div>

                        <button 
                            id="submit-btn"
                            type="submit"
                            class="mt-4 bg-green-900 hover:bg-green-800 text-white font-bold py-4 px-8 rounded-sm shadow-md transition-all duration-300 uppercase text-xs tracking-[0.2em] disabled:opacity-70 disabled:cursor-not-allowed"
                        >
                            Enviar Mensaje
                        </button>

                        <div id="form-feedback" class="hidden text-sm p-4 rounded-sm text-center font-medium transition-all duration-300">
                        </div>
                        
                        <p class="text-[10px] text-stone-400 text-center mt-2 leading-relaxed">
                            Al enviar este formulario, aceptas nuestra política de privacidad y el tratamiento de tus datos para gestionar tu consulta.
                        </p>
                    </form>
                </div>

            </div>
        </div>

        <section class="w-full h-[400px] p-4 relative hover:grayscale-0 transition-all duration-700">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1308.2847920783786!2d-5.980913126137285!3d37.38947654687013!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd126ea7a9b54171%3A0x395d9ad3fd29d9b8!2sLa%20Despensa%20De%20Claudio!5e0!3m2!1ses!2ses!4v1777116442510!5m2!1ses!2ses" class="w-full h-full" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </section>
    </main>
</Layout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const button = document.getElementById("submit-btn") as HTMLButtonElement;
  const feedback = document.getElementById("form-feedback") as HTMLDivElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    
    feedback.classList.add("hidden");
    feedback.classList.remove("bg-green-100", "text-green-800", "bg-red-100", "text-red-800");
    
    const originalText = button.innerText;
    button.innerText = "ENVIANDO...";
    button.disabled = true;

    const formData = new FormData(form);

    try {
      // OJO: Corregido de /api/contact a /api/contacto
      const response = await fetch("/api/contact", {
        method: "POST",
        body: formData,
      });

      const result = await response.json();

      feedback.classList.remove("hidden");

      if (response.ok) {
        button.innerText = "¡ENVIADO!";
        button.classList.replace("bg-green-900", "bg-green-600");
        button.classList.replace("hover:bg-green-800", "hover:bg-green-600");
        
        feedback.classList.add("bg-green-100", "text-green-800");
        feedback.innerText = "¡Gracias! Tu mensaje ha sido enviado con éxito. Te responderemos muy pronto.";
        
        form.reset();

        setTimeout(() => {
            button.innerText = originalText;
            button.classList.replace("bg-green-600", "bg-green-900");
            button.classList.replace("hover:bg-green-600", "hover:bg-green-800");
            button.disabled = false;
            feedback.classList.add("hidden");
        }, 4000);

      } else {
        button.innerText = originalText;
        button.disabled = false;
        
        feedback.classList.add("bg-red-100", "text-red-800");
        feedback.innerText = "Hubo un error: " + result.error;
      }
    } catch (error) {
        button.innerText = originalText;
        button.disabled = false;
        
        feedback.classList.remove("hidden");
        feedback.classList.add("bg-red-100", "text-red-800");
        feedback.innerText = "Error de conexión. Por favor, comprueba tu internet e inténtalo de nuevo.";
    }
  });
</script>