---
import { Image } from "astro:assets";
import { supabase } from "../../../db/supabase";
import Layout from "../../../layouts/Layout.astro";
import defaultImage from "../../../assets/images/no-photo.avif";
import type { ProductDetail } from "../../../types/products";
import ProductBreadcrumb from "../../../components/products/product-id/ProductBreadcrumb.astro";
import ProductBuy from "../../../components/products/product-id/ProductBuy.astro";

const { productId: id } = Astro.params;

const { data, error }: { data: ProductDetail | null, error: any } = await supabase
    .from("products")
    .select("*")
    .eq("id", id)
    .single();

if (error || !data) {
    console.error("Error fetching product:", error?.message);
    return Astro.redirect('/404');
}

const formattedCategory = data.category.charAt(0).toUpperCase() + data.category.slice(1).toLowerCase();
const priceInEuros = data.price / 100;
const weightFormated = data.weight / 1000;
// Formateador de moneda
const priceFormatter = new Intl.NumberFormat('es-ES', {
  style: 'currency',
  currency: 'EUR',
});
---

<Layout title={`${data.name} - La Despensa de Claudio`}>
    <div class="w-full min-h-screen bg-white font-sans text-stone-800 pb-20">
        
        <ProductBreadcrumb category={data.category} name={data.name} formattedCategory={formattedCategory} />

        <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10">
            <div class="flex flex-col lg:flex-row gap-12 lg:gap-20">
                <div class="w-full lg:w-1/2 flex flex-col gap-4">
                    <div class="relative w-full aspect-square bg-stone-100 rounded-sm overflow-hidden border border-stone-200">
                        <Image
                            src={data.url ?? defaultImage}
                            alt={data.name} 
                            class="w-full h-full object-cover object-center"
                            width={50}
                            height={50}
                            loading="eager"
                            transition:name={`product-image-${data.id}`}
                            transition:animate="fade"
                        />
                        <span class="absolute top-4 left-4 bg-green-900 text-white text-xs font-bold px-4 py-1.5 uppercase tracking-widest shadow-md rounded-xs">
                            Calidad Oro
                        </span>
                    </div>
                </div>

                <div class="w-full lg:w-1/2 flex flex-col pt-2 lg:pt-8">
                    
                    <span class="text-xs font-bold uppercase tracking-widest text-stone-400 mb-2">{formattedCategory}</span>
                    <h1 class="text-3xl md:text-5xl font-serif text-green-900 leading-tight mb-4">
                        {data.name}
                    </h1>
                    
                    <div class="text-3xl font-serif font-bold text-gray-900 mb-6">
                        {priceFormatter.format(priceInEuros)}
                        <span class="font-thin text-neutral-500 text-sm">
                            / kg
                        </span>
                    </div>

                    <p class="text-stone-600 font-light leading-relaxed mb-8">
                        {data.description}
                    </p>

                    <ul class="flex flex-col gap-3 py-6 border-y border-stone-200">
                        <li class="flex items-center gap-3">
                            <svg class="w-5 h-5 text-green-800" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                            <span class="text-sm font-medium text-stone-800">Origen: <span class="font-light text-stone-600">{data.origin}</span></span>
                        </li>
                        <li class="flex items-center gap-3">
                            <svg class="w-5 h-5 text-green-800" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path></svg>
                            <span class="text-sm font-medium text-stone-800">Peso estimado: <span class="font-light text-stone-600">{weightFormated} kg</span></span>
                        </li>
                        <li class="flex items-center gap-3">
                            <svg class="w-5 h-5 text-green-800" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            <span class="text-sm font-medium text-stone-800">Curación: <span class="font-light text-stone-600">± {data.curing} meses</span></span>
                        </li>
                    </ul>

                    <ProductBuy product={data}/>

                </div>
            </div>

            <div class="w-full mt-10">
                <div class="border-b border-stone-200 mb-8">
                    <ul class="flex gap-8 text-sm font-bold uppercase tracking-widest">
                        <li class="pb-3 border-b-2 border-green-900 text-green-900 cursor-pointer">Notas de Cata</li>
                    </ul>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12 text-stone-600 font-light leading-relaxed">
                    <div>
                        <h4 class="font-serif text-xl text-green-900 mb-3">Sabor y Aroma</h4>
                        <div class="flex flex-col gap-4 mb-4" set:html={data.taste_notes}>
                            
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>