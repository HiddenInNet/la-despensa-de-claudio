---
import ProductHeader from "../../../components/products/ProductHeader.astro";
import Layout from "../../../layouts/Layout.astro";
import BUS_DATA from "../../../docs/bussiness-data.json";
import ProductCategoriesList from "../../../components/products/ProductCategoriesList.astro";
import ProductCompleteList from "../../../components/products/ProductCompleteList.astro";

const tabName = "Catálogo";

const currentCategory = Astro.url.searchParams.get('cat') || "TODOS";

---

<Layout title={`${tabName} - ${BUS_DATA.bussiness_name}`}>
    <div id={`${tabName}-main-container`} class="w-full min-h-screen bg-stone-50 flex flex-col font-sans text-gray-800">
        
        <ProductHeader />
        <ProductCategoriesList categories={BUS_DATA.products_categories} currentCategory={currentCategory} />
        <ProductCompleteList currentCategory={currentCategory} />

    </div>
</Layout>