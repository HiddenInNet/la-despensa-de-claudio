<div id="ticket-client-data" class="w-full px-4 py-4">
    <form id="ticket-client-form" class="flex flex-col gap-2 items-center">
        <div class="w-full text-start flex flex-col gap-2 max-w-100">
            <label for="name" class="text-xs font-bold uppercase tracking-wider text-neutral-200">Nombre completo</label>
            <input type="text" name="name" id="ticket-client-name" required placeholder="Nombre completo" class="bg-stone-50 border border-stone-200 rounded-sm py-3 px-4 focus:outline-none focus:border-green-800 transition-colors">
        </div>
        <div class="w-full text-start flex flex-col gap-2 max-w-100">
            <label for="phone" class="text-xs font-bold uppercase tracking-wider text-neutral-200">Teléfono</label>
            <input type="number" name="phone" id="ticket-client-phone" required placeholder="Teléfono" class="bg-stone-50 border border-stone-200 rounded-sm py-3 px-4 focus:outline-none focus:border-green-800 transition-colors">
        </div>
    </form>
</div>