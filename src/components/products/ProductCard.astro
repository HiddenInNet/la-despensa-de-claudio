---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import type { ProductsList } from "../../types/products";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const product = Astro.props.product as ProductsList;

// Formateador de moneda
const priceFormatter = new Intl.NumberFormat('es-ES', {
  style: 'currency',
  currency: 'EUR',
});

const formattedCategory = product.category.charAt(0).toUpperCase() + product.category.slice(1).toLowerCase();
const priceInEuros = product.price / 100;
---

<section 
    id={`product-${product.id}-section`} 
    class="group w-full bg-white rounded-2xl border border-neutral-200 shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden flex flex-col"
    transition:animate="slide"
>
    <a href={`/productos/${product.id}`} class="flex flex-col h-full">
        
        <div class="relative w-full h-52 overflow-hidden bg-neutral-100">
            <img 
                src={"/images/montesierra-jamon-100.webp"} 
                alt={`Imagen de ${product.name}`} 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ease-in-out" 
                loading="lazy"
            />
            <span class="absolute top-3 left-3 bg-white/95 text-neutral-800 text-xs font-semibold px-3 py-1 rounded-full shadow-sm backdrop-blur-sm">
                {formattedCategory}
            </span>
        </div>

        <div class="flex flex-col flex-grow p-5">
            <div class="flex-grow">
                <h3 class="text-xl font-bold text-green-900 leading-tight mb-2">
                    {product.name}
                </h3>
                <p class="text-neutral-600 text-sm line-clamp-3">
                    {product.description}
                </p>
            </div>
            
            <div class="flex items-center justify-between mt-5 pt-4 border-t border-neutral-100">
                <span class="text-xl font-extrabold text-neutral-900">
                    {priceFormatter.format(priceInEuros)}
                </span>
                <span class="text-sm font-medium text-green-800 bg-green-50 px-4 py-2 rounded-lg group-hover:bg-green-800 group-hover:text-white transition-colors duration-300">
                    Ver más
                </span>
            </div>
        </div>
    </a>
</section>