---
import { Image } from "astro:assets";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import defaultImage from "../../assets/images/no-photo.avif";
import type { ProductsList } from "../../types/products";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const product = Astro.props.product as ProductsList;

// Formateador de moneda
const priceFormatter = new Intl.NumberFormat('es-ES', {
  style: 'currency',
  currency: 'EUR',
});

const formattedCategory = product.category.charAt(0).toUpperCase() + product.category.slice(1).toLowerCase();
const priceInEuros = product.price / 100;

---

<article 
    id={`product-${product.id}-section`} 
    class="group w-full bg-white rounded-sm border border-stone-200 shadow-sm hover:shadow-lg hover:border-green-700 transition-all duration-300 overflow-hidden flex flex-col"
>
    <a href={`./products/${product.id}`} class="flex flex-col h-full">
        
        <div class="relative w-full h-56 overflow-hidden bg-stone-100">
            <Image
                src={product.url ?? defaultImage}
                alt={`${product.name}`} 
                width="50"
                height="50"
                loading="lazy"
                transition:name={`product-image-${product.id}`}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-in-out" 
            />
            <span class="absolute top-3 left-3 bg-green-900 text-white text-[10px] font-bold px-3 py-1 uppercase tracking-widest shadow-md">
                {formattedCategory}
            </span>
        </div>

        <div class="flex flex-col flex-grow p-6">
            <div class="flex-grow">
                <h3 class="text-xl font-serif font-bold text-green-900 leading-tight mb-3 group-hover:text-green-700 transition-colors">
                    {product.name}
                </h3>
                <p class="text-stone-500 text-sm line-clamp-3 font-light leading-relaxed">
                    {product.description}
                </p>
            </div>
            
            <div class="flex items-center justify-between mt-6 pt-4 border-t border-stone-100">
                <span class="text-2xl font-serif font-bold text-gray-900">
                    {priceFormatter.format(priceInEuros)} 
                    <span class="font-thin text-neutral-500 text-sm">
                        / kg
                    </span>
                </span>
                <span class="text-xs font-bold uppercase tracking-widest text-green-800 border-b-2 border-transparent group-hover:border-green-800 transition-all duration-300 pb-0.5">
                    Ver Detalles →
                </span>
            </div>
        </div>
    </a>
</article>