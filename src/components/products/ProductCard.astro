---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import type { ProductsList } from "../../types/products";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface ProductCardProps {
    product: ProductsList;
}

const product = Astro.props.product as ProductsList;
---
<section id="" class="w-full h-fit flex p-2 border-1 border-neutral-300 rounded-xl drop-shadow-md bg-neutral-100" transition:animate="slide">
    <a href="" class="w-full h-fit grid grid-cols-2 gap-5">
        <img src={product.image} alt="" class="w-40 h-40 object-cover drop-shadow-sm drop-shadow-neutral-900" loading="lazy"/>
        <div class="flex flex-col justify-center">
            <h3 class="text-2xl font-bold text-green-900">{product.name}</h3>
            <p class="prose prose-md">{product.description}</p>
        </div>
    </a>
</section>