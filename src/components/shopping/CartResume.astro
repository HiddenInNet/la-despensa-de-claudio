---
import Delete from "../../assets/svg/delete.svg";
---

<div class="p-6 border-t border-neutral-100 bg-stone-50 shadow-[0_-10px_20px_-15px_rgba(0,0,0,0.1)]">
    <div class="flex justify-between items-center mb-4">
        <span class="text-stone-500 font-medium text-sm">Total estimado</span>
        <span id="total-price" class="text-2xl font-bold text-green-900"></span>
    </div>
    <div class="flex flex-row gap-2">
        <button id="remove-order" class="px-4 bg-red-500 hover:bg-red-400 text-white rounded-md hover:cursor-pointer transition-colors">
            <Delete />
        </button>
        <a id="continue-order" href={"/es/order"} class="w-full bg-green-800 text-white text-center font-bold py-4 rounded-md hover:bg-green-700 hover:cursor-pointer transition-colors uppercase tracking-widest text-sm shadow-md">
            Hacer pedido
        </a>
    </div>
</div>

<script>
    import type { ShopItem } from "../../types/shop";
    import { calculatePrice } from "../../utils/PriceCalculator";
    import { getProductListFromLocalStorage, removeProductListFromLocalStorage } from "../../utils/ShopCartScripts";

    async function getTotalPrice () {
        const total = await calculatePrice(getProductListFromLocalStorage());
        const totalFormatted = (total / 100).toLocaleString('es-ES', { 
            style: 'currency', 
            currency: 'EUR' 
        });

        const totalPriceSpan = document.getElementById("total-price") as HTMLSpanElement;
        if (!totalPriceSpan) return;

        totalPriceSpan.innerText = totalFormatted;
    }

    function initCartActions() {
        getTotalPrice();

        const removeBtn = document.getElementById("remove-order") as HTMLButtonElement;
        if (!removeBtn) return;

        function removeItems() {
            removeProductListFromLocalStorage();
            window.dispatchEvent(new CustomEvent('cart-updated'));
        }

        removeBtn.removeEventListener("click", removeItems);
        removeBtn.addEventListener("click", removeItems);
    }

    async function sendDelivery () {
        try {
            const cartItems: ShopItem[] = getProductListFromLocalStorage();

            if (cartItems.length === 0) {
                alert("El carrito está vacío");
                return;
            }

            const response = await fetch("/api/payment", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify({ items: cartItems })
            });
            
            if (response.ok) {
                localStorage.removeItem("SHOP_LIST"); 
                window.dispatchEvent(new CustomEvent('cart-updated'));
            }
        } catch (error) {
            console.error("Error al enviar el pedido:", error);
        }
    }
    
    window.addEventListener("cart-updated", getTotalPrice);
    window.addEventListener("refresh-total-price", getTotalPrice);
    document.addEventListener("astro:page-load", initCartActions);
</script>