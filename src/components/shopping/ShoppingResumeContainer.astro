---
import Close from "../../assets/svg/close.svg";
import Delete from "../../assets/svg/delete.svg";
---

<div 
    id="cart-backdrop" 
    class="fixed inset-0 bg-neutral-900/40 z-40 opacity-0 pointer-events-none transition-opacity duration-300 backdrop-blur-sm"
></div>

<section 
    id="cart-drawer" 
    class="fixed bottom-0 left-0 w-full md:w-[450px] md:left-auto md:right-5 md:bottom-5 md:rounded-2xl h-[80vh] md:h-[600px] max-h-screen bg-white z-50 transform translate-y-full transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] rounded-t-3xl shadow-2xl flex flex-col overflow-hidden"
>
    <div class="p-6 border-b border-neutral-100 flex justify-between items-center bg-stone-50">
        <h2 class="text-2xl font-serif text-green-900">Tu Despensa</h2>
        <button id="close-cart-btn" class="p-2 text-red-500 hover:text-red-400 hover:bg-stone-200 hover:cursor-pointer rounded-full transition-colors" aria-label="Cerrar carrito">
            <Close />
        </button>
    </div>

    <div class="flex-1 overflow-y-auto p-6 flex flex-col gap-4">
        <div class="flex gap-4 pb-4 border-b border-stone-100">
            <div class="w-20 h-20 bg-stone-200 rounded-md overflow-hidden">
                <!-- <img src="/placeholder-jamon.jpg" alt="" class="w-full h-full object-cover opacity-50" /> -->
            </div>
            <div class="flex-1">
                <h3 class="font-bold text-stone-800 text-sm leading-tight">Jamón de Bellota 100% Ibérico</h3>
                <p class="text-stone-500 text-xs mt-1">1 x 65.00 €</p>
            </div>
            <button class="text-stone-300 hover:text-red-500 hover:cursor-pointer transition-colors self-start">
                <Delete />
            </button>
        </div>
    </div>

    <div class="p-6 border-t border-neutral-100 bg-stone-50 shadow-[0_-10px_20px_-15px_rgba(0,0,0,0.1)]">
        <div class="flex justify-between items-center mb-4">
            <span class="text-stone-500 font-medium text-sm">Total estimado</span>
            <span class="text-2xl font-bold text-green-900">65.00 €</span>
        </div>
        <button class="w-full bg-green-800 text-white text-center font-bold py-4 rounded-md hover:bg-green-700 transition-colors uppercase tracking-widest text-sm shadow-md">
            Finalizar Compra
        </button>
    </div>
</section>